{
  "rewrites": [
    { "source": "/lead-capture", "destination": "/lead-capture.html" },
    { "source": "/lead-capture.html", "destination": "/lead-capture.html" },
    { "source": "/lead-capture-ai", "destination": "/lead-capture-ai.html" },
    { "source": "/lead-capture-ai.html", "destination": "/lead-capture-ai.html" },
    { "source": "/(.*)\\.html", "destination": "/$1.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
