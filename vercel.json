{
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.txt", "use": "@vercel/static" },
    { "src": "llms.txt", "use": "@vercel/static" },
    { "src": "*.xml", "use": "@vercel/static" },
    { "src": "blog/*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.svg", "use": "@vercel/static" },
    { "src": "*.ico", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/public/(.*)", "destination": "/public/$1" },
    { "source": "/api/direct-qualify", "destination": "/api/direct-qualify.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/leads", "destination": "/api/leads.js" },
    { "source": "/api/analytics", "destination": "/api/analytics.js" },
    { "source": "/api/health", "destination": "/api/health.js" },
    { "source": "/api/instagram", "destination": "/api/instagram.js" },
    { "source": "/api/send-outreach", "destination": "/api/send-outreach.js" },
    { "source": "/api/resend-webhook", "destination": "/api/resend-webhook.js" },
    { "source": "/api/email", "destination": "/api/email.js" },
    { "source": "/api/dashboard", "destination": "/api/dashboard.js" },
    { "source": "/api/call", "destination": "/api/call.js" },
    { "source": "/api/call-log", "destination": "/api/call-log.js" },
    { "source": "/api/x-callback", "destination": "/api/x-callback.js" }
  ],
  "redirects": [
    { "source": "/(.*)", "destination": "https://focusrunner.io/$1", "has": [{"type": "host", "value": "www.focusrunner.com"}], "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS, GET" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Client-Id" }
      ]
    },
    {
      "source": "\\.(svg|png|jpg|jpeg|gif|ico|webp|avif)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "\\.(css|js|woff|woff2)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "\\.(xml|txt)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/blog/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=2592000" }
      ]
    }
  ]
}
